function getStaffMap(clef){ return clef==='bass'?BASS_Y:clef==='alto'?ALTO_Y:TREBLE_Y; }

function findY(writtenPitch, clef, instId){
  const map = getStaffMap(clef);
  const octaves = clef==='bass'?[2,3,4,1]:clef==='alto'?[3,4]:[4,5,3,6];
  for(const o of octaves){
    const k = writtenPitch+o;
    if(map[k]) return {noteId:k,...map[k]};
  }
  for(const [k,v] of Object.entries(map)){
    if(k.replace(/\d/g,'')=== writtenPitch) return {noteId:k,...v};
  }
  return null;
}

