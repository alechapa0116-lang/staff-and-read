let instFam='all';
function setInstFilter(fam,btn){
  instFam=fam;
  document.querySelectorAll('#inst-filters .ftag').forEach(b=>b.classList.toggle('on',b.dataset.fam===fam));
  filterInsts();
}

function buildInstGrid(){
  const g=document.getElementById('inst-grid');
  g.innerHTML='';
  Object.entries(INSTRUMENTS).forEach(([id,d])=>{
    const b=document.createElement('button');
    b.className='ibtn'; b.dataset.id=id; b.dataset.fam=d.family; b.dataset.name=d.name.toLowerCase();
    b.innerHTML=`<span class="ii">${d.icon}</span><span>${d.name}</span><span class="ik">${d.key}</span>`;
    b.onclick=()=>selectInst(id,b);
    g.appendChild(b);
  });
}

function filterInsts(){
  const q=document.getElementById('inst-search').value.toLowerCase();
  document.querySelectorAll('.ibtn').forEach(b=>{
    const famOk = instFam==='all' || b.dataset.fam===instFam;
    const qOk = !q || b.dataset.name.includes(q) || b.dataset.fam.toLowerCase().includes(q);
    b.classList.toggle('hidden', !(famOk&&qOk));
  });
}

function selectInst(id,btn){
  selInst=id;
  document.querySelectorAll('.ibtn').forEach(b=>b.classList.toggle('sel',b.dataset.id===id));
  updateStartBtn();
  buildScaleList();
}

function buildScaleFilters(){
  const row=document.getElementById('scale-filters');
  row.innerHTML='<button class="ftag on" data-cat="all" onclick="setScaleCat(\'all\',this)">All</button>';
  Object.keys(SCALE_CATS).forEach(cat=>{
    const b=document.createElement('button');
    b.className='ftag'; b.dataset.cat=cat; b.textContent=cat;
    b.onclick=()=>setScaleCat(cat,b);
    row.appendChild(b);
  });
}

let scaleCat='all';
function setScaleCat(cat,btn){
  scaleCat=cat;
  document.querySelectorAll('#scale-filters .ftag').forEach(b=>b.classList.toggle('on',b.dataset.cat===cat));
  filterScales();
}

function buildScaleList(){
  const inst=INSTRUMENTS[selInst];
  const list=document.getElementById('scale-list');
  list.innerHTML='';
  Object.entries(ALL_SCALES).forEach(([name,d])=>{
    const btn=document.createElement('button');
    btn.className='sbtn'; btn.dataset.name=name.toLowerCase(); btn.dataset.cat=d.c;
    // Show notes as written for this instrument
    const written=d.notes.slice(0,6).map(n=>transposePitch(n,inst.transpose));
    const col=SCALE_CATS[d.c]||'#888';
    btn.innerHTML=`
      <div class="sbtn-dot" style="background:${col}"></div>
      <div class="sbtn-info">
        <div class="sbtn-name">${name}</div>
        <div class="sbtn-cat">${d.c} · ${written.join(' ')}</div>
      </div>
      <div class="sbtn-check">✓</div>`;
    btn.onclick=()=>toggleScale(name,btn);
    if(selScales.has(name)) btn.classList.add('sel');
    list.appendChild(btn);
  });
  updateScaleCount();
}

function filterScales(){
  const q=document.getElementById('scale-search').value.toLowerCase();
  document.querySelectorAll('.sbtn').forEach(b=>{
    const catOk=scaleCat==='all'||b.dataset.cat===scaleCat;
    const qOk=!q||b.dataset.name.includes(q)||b.dataset.cat.toLowerCase().includes(q);
    b.classList.toggle('hidden',!(catOk&&qOk));
  });
}

function toggleScale(name,btn){
  if(selScales.has(name)){selScales.delete(name);btn.classList.remove('sel');}
  else{selScales.add(name);btn.classList.add('sel');}
  updateScaleCount();
  updateStartBtn();
}

function updateScaleCount(){
  document.getElementById('scale-count').textContent=selScales.size;
}
function updateStartBtn(){
  document.getElementById('start-btn').disabled=!selInst||selScales.size===0;
}

