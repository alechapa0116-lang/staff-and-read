<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Staff & Read — Ultimate Band Trainer</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#08090d;--surface:#0f1018;--card:#141620;--card2:#1a1d2e;
  --border:#232640;--border2:#2e3258;
  --accent:#6ee7f7;--gold:#f5c842;--red:#ff6b6b;--green:#4fffb0;
  --purple:#b48eff;--pink:#ff79c6;--orange:#ffb347;
  --text:#dde3f0;--muted:#4a5070;--muted2:#6a7090;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Fira Code',monospace;min-height:100vh;overflow-x:hidden}

/* scanlines */
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:9998;
  background:repeating-linear-gradient(180deg,transparent 0px,transparent 3px,rgba(0,0,0,0.04) 3px,rgba(0,0,0,0.04) 4px)}

.screen{display:none;min-height:100vh;flex-direction:column;align-items:center}
.screen.active{display:flex}

/* ══ MENU ══ */
#menu{padding:28px 16px 48px;gap:0;max-width:100%}

.logo-wrap{text-align:center;margin-bottom:32px}
.logo{font-family:'Unbounded',sans-serif;font-size:clamp(36px,8vw,80px);
  font-weight:900;letter-spacing:-0.02em;line-height:1;
  background:linear-gradient(120deg,var(--accent) 0%,var(--purple) 50%,var(--pink) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.logo-sub{font-size:9px;letter-spacing:0.4em;color:var(--muted);text-transform:uppercase;margin-top:6px}

.menu-cols{display:grid;grid-template-columns:1fr 1fr;gap:16px;width:100%;max-width:1100px;margin-bottom:20px}
@media(max-width:768px){.menu-cols{grid-template-columns:1fr}}

.panel{background:var(--surface);border:1px solid var(--border);padding:16px}
.panel-title{font-family:'Unbounded',sans-serif;font-size:10px;font-weight:700;
  letter-spacing:0.25em;color:var(--muted);text-transform:uppercase;
  margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border)}

/* search box */
.search-box{position:relative;margin-bottom:10px}
.search-box input{width:100%;background:var(--card);border:1px solid var(--border);
  color:var(--text);padding:8px 12px 8px 32px;font-family:'Fira Code',monospace;font-size:11px;
  outline:none;transition:border-color 0.2s}
.search-box input:focus{border-color:var(--accent)}
.search-box::before{content:'⌕';position:absolute;left:10px;top:50%;transform:translateY(-50%);
  color:var(--muted);font-size:14px;pointer-events:none}
.search-box input::placeholder{color:var(--muted)}

/* filter tags */
.filter-row{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px}
.ftag{background:var(--card);border:1px solid var(--border);color:var(--muted);
  padding:3px 10px;font-size:9px;letter-spacing:0.1em;cursor:pointer;
  text-transform:uppercase;transition:all 0.15s;font-family:'Fira Code',monospace}
.ftag:hover{border-color:var(--accent);color:var(--accent)}
.ftag.on{background:rgba(110,231,247,0.1);border-color:var(--accent);color:var(--accent)}

/* instrument grid */
.inst-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:6px;
  max-height:340px;overflow-y:auto;padding-right:4px}
.inst-grid::-webkit-scrollbar{width:4px}
.inst-grid::-webkit-scrollbar-track{background:var(--card)}
.inst-grid::-webkit-scrollbar-thumb{background:var(--border2)}

.ibtn{background:var(--card);border:1.5px solid var(--border);color:var(--muted2);
  padding:10px 6px;font-family:'Fira Code',monospace;font-size:10px;
  cursor:pointer;transition:all 0.15s;text-align:center;display:flex;
  flex-direction:column;align-items:center;gap:4px;line-height:1.3}
.ibtn .ii{font-size:20px}
.ibtn .ik{font-size:8px;color:var(--muted);border:1px solid var(--border);
  padding:1px 4px;margin-top:2px}
.ibtn:hover{border-color:var(--accent);color:var(--text)}
.ibtn.sel{border-color:var(--accent);background:rgba(110,231,247,0.07);color:var(--accent)}
.ibtn.sel .ik{border-color:rgba(110,231,247,0.4);color:var(--accent)}
.ibtn.hidden{display:none}

/* scale grid */
.scale-list{display:flex;flex-direction:column;gap:4px;
  max-height:340px;overflow-y:auto;padding-right:4px}
.scale-list::-webkit-scrollbar{width:4px}
.scale-list::-webkit-scrollbar-track{background:var(--card)}
.scale-list::-webkit-scrollbar-thumb{background:var(--border2)}

.sbtn{background:var(--card);border:1.5px solid var(--border);
  padding:8px 12px;cursor:pointer;transition:all 0.15s;
  display:flex;align-items:center;gap:10px}
.sbtn:hover{border-color:var(--gold)}
.sbtn.sel{border-color:var(--gold);background:rgba(245,200,66,0.06)}
.sbtn.hidden{display:none}
.sbtn-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.sbtn-info{flex:1;min-width:0}
.sbtn-name{font-size:11px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sbtn.sel .sbtn-name{color:var(--gold)}
.sbtn-cat{font-size:9px;color:var(--muted);letter-spacing:0.1em}
.sbtn-check{width:14px;height:14px;border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0}
.sbtn.sel .sbtn-check{background:var(--gold);border-color:var(--gold);color:#000}

.sel-count{font-size:10px;color:var(--muted);margin-top:6px}
.sel-count span{color:var(--accent)}

.start-area{display:flex;flex-direction:column;align-items:center;gap:10px;
  width:100%;max-width:1100px}
.start-btn{background:linear-gradient(135deg,var(--accent),var(--purple));
  color:#000;border:none;padding:16px 64px;
  font-family:'Unbounded',sans-serif;font-size:20px;font-weight:700;
  cursor:pointer;transition:all 0.2s;letter-spacing:0.05em}
.start-btn:hover{transform:translateY(-2px);filter:brightness(1.1)}
.start-btn:disabled{background:var(--muted);cursor:not-allowed;transform:none;filter:none}
.guide-btn{background:none;border:1px solid var(--border);color:var(--muted);
  padding:8px 24px;font-family:'Fira Code',monospace;font-size:10px;
  cursor:pointer;letter-spacing:0.15em;transition:all 0.15s}
.guide-btn:hover{border-color:var(--text);color:var(--text)}

/* ══ GAME ══ */
#game{padding:14px 16px;gap:10px;align-items:center}

.gtop{display:flex;width:100%;max-width:760px;
  justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.gbk{background:none;border:1px solid var(--border);color:var(--muted);
  padding:6px 14px;font-family:'Fira Code',monospace;font-size:10px;
  cursor:pointer;transition:all 0.15s;letter-spacing:0.1em}
.gbk:hover{border-color:var(--text);color:var(--text)}
.gbadge{font-size:9px;letter-spacing:0.2em;color:var(--accent);
  border:1px solid rgba(110,231,247,0.25);padding:4px 10px;text-transform:uppercase}
.gscore{display:flex;gap:14px;font-size:11px}
.gs-c{color:var(--green);font-weight:500}
.gs-w{color:var(--red);font-weight:500}

.prog{width:100%;max-width:760px;height:2px;background:var(--border)}
.prog-f{height:100%;background:linear-gradient(90deg,var(--accent),var(--purple));transition:width .4s}

/* staff */
.staff-box{width:100%;max-width:760px;background:#090b10;
  border:1px solid var(--border);padding:12px 10px 16px;position:relative}
.staff-qlabel{font-family:'Unbounded',sans-serif;font-size:10px;font-weight:700;
  letter-spacing:0.3em;color:var(--muted);text-align:center;margin-bottom:8px}
#staff-svg{width:100%;display:block}

/* answer */
.ans-area{width:100%;max-width:760px;display:flex;flex-direction:column;gap:6px}
.nbtns{display:grid;grid-template-columns:repeat(7,1fr);gap:5px}
.nbtn{background:var(--card);border:2px solid var(--border);color:var(--text);
  padding:14px 4px;font-family:'Unbounded',sans-serif;font-size:18px;font-weight:700;
  cursor:pointer;transition:all 0.12s;text-align:center}
.nbtn:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}
.nbtn.sel{border-color:var(--accent);color:var(--accent);background:rgba(110,231,247,0.07)}
.nbtn.fc{background:var(--green);border-color:var(--green);color:#000;animation:pop .3s}
.nbtn.fw{background:var(--red);border-color:var(--red);color:#fff;animation:wag .3s}

.acbtns{display:grid;grid-template-columns:repeat(3,1fr);gap:5px}
.acbtn{background:var(--card);border:2px solid var(--border);color:var(--muted);
  padding:9px;font-family:'Fira Code',monospace;font-size:11px;font-weight:500;
  cursor:pointer;transition:all 0.12s;text-align:center}
.acbtn:hover{border-color:var(--purple);color:var(--purple)}
.acbtn.sel{border-color:var(--purple);background:rgba(180,142,255,0.08);color:var(--purple)}

.ans-disp{text-align:center;padding:8px;font-family:'Unbounded',sans-serif;
  font-size:40px;font-weight:900;color:var(--text);min-height:58px;
  background:var(--card);border:1px solid var(--border)}

.actbtns{display:grid;grid-template-columns:1fr 2fr 1fr;gap:5px}
.actbtn{padding:13px;border:2px solid;font-family:'Unbounded',sans-serif;
  font-size:14px;font-weight:700;letter-spacing:0.08em;cursor:pointer;
  transition:all 0.15s;background:transparent}
.ab-retry{border-color:var(--border);color:var(--muted)}
.ab-retry:hover{border-color:var(--text);color:var(--text)}
.ab-check{border-color:var(--accent);color:var(--accent)}
.ab-check:hover{background:var(--accent);color:#000}
.ab-next{border-color:var(--green);color:var(--green)}
.ab-next:hover{background:var(--green);color:#000}

.correct-msg{font-family:'Unbounded',sans-serif;font-size:44px;font-weight:900;
  color:var(--green);text-align:center;letter-spacing:0.05em;
  animation:pop .4s ease;display:none}

/* info panel */
.ipanel{width:100%;max-width:760px;background:var(--card2);
  border-left:3px solid var(--red);padding:14px 16px;display:none;animation:slin .2s}
.ipanel.show{display:block}
.ipanel h3{font-family:'Unbounded',sans-serif;font-size:16px;font-weight:700;
  color:var(--gold);letter-spacing:0.05em;margin-bottom:10px}
.ipcols{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:500px){.ipcols{grid-template-columns:1fr}}
.ipc label{font-size:8px;text-transform:uppercase;letter-spacing:0.2em;
  color:var(--muted);display:block;margin-bottom:3px}
.ipc p,.ipc div{font-size:11px;color:var(--text);line-height:1.6}
.frow{display:flex;flex-wrap:wrap;gap:4px;margin-top:4px}
.fdot{width:30px;height:30px;border-radius:50%;border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;color:var(--muted)}
.fdot.on{background:var(--gold);border-color:var(--gold);color:#000;font-weight:700}
.fdot.tag{border-radius:3px;width:auto;padding:0 6px;font-size:9px}
.shint{background:rgba(110,231,247,0.04);border:1px solid rgba(110,231,247,0.15);
  padding:8px 12px;font-size:10px;color:var(--text);line-height:1.7;margin-top:8px}
.shint strong{color:var(--accent)}

/* ══ GUIDE ══ */
#guide{padding:28px 16px 48px;gap:16px;align-items:center}
#guide h1{font-family:'Unbounded',sans-serif;font-size:clamp(24px,5vw,48px);
  font-weight:900;color:var(--accent);letter-spacing:0.02em;text-align:center}

.guide-search{position:relative;width:100%;max-width:900px;margin-bottom:8px}
.guide-search input{width:100%;background:var(--surface);border:1px solid var(--border);
  color:var(--text);padding:10px 14px 10px 36px;font-family:'Fira Code',monospace;font-size:12px;
  outline:none;transition:border-color 0.2s}
.guide-search input:focus{border-color:var(--accent)}
.guide-search::before{content:'⌕';position:absolute;left:12px;top:50%;transform:translateY(-50%);
  color:var(--muted);font-size:16px}

.guide-filters{display:flex;flex-wrap:wrap;gap:5px;width:100%;max-width:900px;margin-bottom:12px}

.guide-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:12px;width:100%;max-width:900px}
.gcard{background:var(--card);border:1px solid var(--border);
  border-top:3px solid;padding:16px;transition:border-color 0.2s}
.gcard.hidden{display:none}
.gcard h3{font-family:'Unbounded',sans-serif;font-size:13px;font-weight:700;
  letter-spacing:0.03em;margin-bottom:6px}
.gcard p{font-size:10px;color:var(--muted);line-height:1.7;margin-bottom:8px}
.gpills{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:8px}
.gpill{background:var(--bg);border:1px solid var(--border);padding:2px 7px;
  font-size:9px;font-weight:500;color:var(--accent)}
.gtip{background:rgba(245,200,66,0.05);border-left:2px solid var(--gold);
  padding:6px 10px;font-size:9px;color:var(--muted);line-height:1.6}
.gtip strong{color:var(--gold)}
.gcat-tag{display:inline-block;font-size:8px;letter-spacing:0.15em;
  text-transform:uppercase;padding:2px 6px;border:1px solid var(--border);
  color:var(--muted);margin-bottom:6px}

/* flash */
#flash{position:fixed;inset:0;pointer-events:none;z-index:9997;opacity:0;transition:opacity .12s}
#flash.c{background:rgba(79,255,176,0.06);opacity:1}
#flash.w{background:rgba(255,107,107,0.06);opacity:1}

@keyframes pop{0%{transform:scale(1)}50%{transform:scale(1.1)}100%{transform:scale(1)}}
@keyframes wag{0%,100%{transform:translateX(0)}25%{transform:translateX(-4px)}75%{transform:translateX(4px)}}
@keyframes slin{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}

@media(max-width:500px){
  .nbtns{grid-template-columns:repeat(4,1fr)}
  .actbtns{grid-template-columns:1fr 1fr 1fr}
  .inst-grid{grid-template-columns:repeat(3,1fr)}
}
</style>
</head>
<body>
<div id="flash"></div>

<!-- ══════════════ MENU ══════════════ -->
<div class="screen active" id="menu">
  <div class="logo-wrap">
    <div class="logo">STAFF &amp; READ</div>
    <div class="logo-sub">Ultimate Band Note Trainer · v3</div>
  </div>

  <div class="menu-cols">
    <!-- LEFT: INSTRUMENTS -->
    <div class="panel">
      <div class="panel-title">① Instrument</div>
      <div class="search-box"><input type="text" id="inst-search" placeholder="Search instruments..." oninput="filterInsts()"></div>
      <div class="filter-row" id="inst-filters"></div>
      <div class="inst-grid" id="inst-grid"></div>
    </div>

    <!-- RIGHT: SCALES -->
    <div class="panel">
      <div class="panel-title">② Scales / Note Pools</div>
      <div class="search-box"><input type="text" id="scale-search" placeholder="Search scales..." oninput="filterScales()"></div>
      <div class="filter-row" id="scale-filters"></div>
      <div class="scale-list" id="scale-list"></div>
      <div class="sel-count">Selected: <span id="scale-count">0</span> scale(s)</div>
    </div>
  </div>

  <div class="start-area">
    <button class="start-btn" id="start-btn" disabled onclick="startGame()">START TRAINING</button>
    <button class="guide-btn" onclick="showGuide()">SCALE GUIDE &amp; REFERENCE</button>
  </div>
</div>

<!-- ══════════════ GAME ══════════════ -->
<div class="screen" id="game">
  <div class="gtop">
    <button class="gbk" onclick="goMenu()">← Menu</button>
    <div class="gbadge" id="gbadge">—</div>
    <div class="gscore">✓ <span class="gs-c" id="gsc">0</span> &nbsp; ✗ <span class="gs-w" id="gsw">0</span></div>
  </div>
  <div class="prog"><div class="prog-f" id="prog" style="width:0%"></div></div>

  <div class="staff-box">
    <div class="staff-qlabel" id="sqlbl">IDENTIFY THIS NOTE</div>
    <svg id="staff-svg" viewBox="0 0 760 200" xmlns="http://www.w3.org/2000/svg"></svg>
  </div>

  <div class="correct-msg" id="cmsg">CORRECT!</div>
  <div class="ipanel" id="ipanel">
    <h3 id="iptitle">—</h3>
    <div class="ipcols" id="ipcols"></div>
    <div class="shint" id="iphint"></div>
  </div>

  <div class="ans-area">
    <div class="nbtns" id="nbtns"></div>
    <div class="acbtns" id="acbtns"></div>
    <div class="ans-disp" id="ansdisp">—</div>
    <div class="actbtns">
      <button class="actbtn ab-retry" onclick="retry()">RETRY</button>
      <button class="actbtn ab-check" onclick="checkAns()">CHECK ANSWER</button>
      <button class="actbtn ab-next" onclick="nextNote()">NEXT →</button>
    </div>
  </div>
</div>

<!-- ══════════════ GUIDE ══════════════ -->
<div class="screen" id="guide">
  <h1>COMPLETE SCALE REFERENCE</h1>
  <div class="guide-search"><input type="text" id="guide-search" placeholder="Search any scale name, category, notes..." oninput="filterGuide()"></div>
  <div class="guide-filters" id="guide-filter-row"></div>
  <div class="guide-grid" id="guide-grid"></div>
  <button class="start-btn" onclick="goMenu()" style="margin-top:20px;padding:14px 40px;font-size:16px">← BACK TO MENU</button>
</div>

<script>
// ════════════════════════════════════════════════════════════════
// CHROMATIC HELPERS
// ════════════════════════════════════════════════════════════════
const SEMI = ['C','Db','D','Eb','E','F','Gb','G','Ab','A','Bb','B'];
const ENHAR = {'C#':'Db','D#':'Eb','F#':'Gb','G#':'Ab','A#':'Bb','Cb':'B','Fb':'E','Bs':'C','Es':'F'};

function normalize(n){ return ENHAR[n] || n; }
function semiIdx(n){ return SEMI.indexOf(normalize(n)); }
function transposePitch(n, semi){
  const i = semiIdx(n); if(i<0) return n;
  return SEMI[(i+semi+12)%12];
}

// ════════════════════════════════════════════════════════════════
// INSTRUMENTS — 40+ instruments
// transpose: semitones written ABOVE concert pitch
// ════════════════════════════════════════════════════════════════
const INSTRUMENTS = {
  // ── BRASS ──
  trombone:    {name:'Trombone',    icon:'🎺', family:'Brass',    clef:'bass',   transpose:0,  key:'Concert',  ft:'trombone', desc:'Concert pitch. Bass clef. 7 slide positions. The backbone of the brass section.'},
  altTrombone: {name:'Alto Trombone',icon:'🎺',family:'Brass',   clef:'alto',   transpose:0,  key:'Concert',  ft:'trombone', desc:'Concert pitch. Alto clef (middle C on middle line). Smaller bore, higher range.'},
  bassTrombone:{name:'Bass Trombone',icon:'🎺',family:'Brass',   clef:'bass',   transpose:0,  key:'Concert',  ft:'trombone', desc:'Concert pitch. Bass clef. Has a trigger/valve extending range down.'},
  euphonium:   {name:'Euphonium',   icon:'🎶', family:'Brass',    clef:'bass',   transpose:0,  key:'Concert',  ft:'valve3',   desc:'Concert pitch. Bass clef. 3 valves. Warm, lyrical tone.'},
  baritoneTc:  {name:'Baritone (TC)',icon:'🎶',family:'Brass',   clef:'treble', transpose:2,  key:'Bb',       ft:'valve3',   desc:'Bb transposing treble clef version of baritone horn.'},
  tuba:        {name:'Tuba',        icon:'🔔', family:'Brass',    clef:'bass',   transpose:0,  key:'Concert',  ft:'valve3',   desc:'Concert pitch. Bass clef. Lowest brass. 3 or 4 valves.'},
  sousaphone:  {name:'Sousaphone',  icon:'🔔', family:'Brass',    clef:'bass',   transpose:0,  key:'Concert',  ft:'valve3',   desc:'Concert pitch. Bass clef. Marching version of tuba.'},
  trumpet:     {name:'Trumpet',     icon:'🎺', family:'Brass',    clef:'treble', transpose:2,  key:'Bb',       ft:'valve3',   desc:'Bb transposing. Treble clef. Bright and penetrating. 3 valves.'},
  cornet:      {name:'Cornet',      icon:'🎺', family:'Brass',    clef:'treble', transpose:2,  key:'Bb',       ft:'valve3',   desc:'Bb transposing. Same as trumpet, slightly mellower tone.'},
  flugelhorn:  {name:'Flugelhorn',  icon:'🎺', family:'Brass',    clef:'treble', transpose:2,  key:'Bb',       ft:'valve3',   desc:'Bb transposing. Wide conical bore — very warm, jazz-friendly.'},
  piccTrumpet: {name:'Picc Trumpet',icon:'🎺', family:'Brass',    clef:'treble', transpose:2,  key:'Bb',       ft:'valve3',   desc:'Bb piccolo trumpet. Tiny, brilliant high range. 4 valves.'},
  frenchHorn:  {name:'French Horn', icon:'🪗', family:'Brass',    clef:'treble', transpose:7,  key:'F',        ft:'horn',     desc:'F transposing. Writes a perfect 5th above concert. Very complex harmonic series.'},
  melloHorn:   {name:'Mellophone',  icon:'🪗', family:'Brass',    clef:'treble', transpose:9,  key:'Eb/F',     ft:'valve3',   desc:'Eb/F transposing. Marching band version of French horn.'},
  wagnerTuba:  {name:'Wagner Tuba', icon:'🎶', family:'Brass',    clef:'treble', transpose:7,  key:'F',        ft:'horn',     desc:'F transposing. Hybrid horn/tuba. Wagner invented it for Der Ring.'},
