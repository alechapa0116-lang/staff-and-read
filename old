}

function buildInstFilters(){
  const families = [...new Set(Object.values(INSTRUMENTS).map(i=>i.family))];
  const row = document.getElementById('inst-filters');
  row.innerHTML = '<button class="ftag on" data-fam="all" onclick="setInstFilter(\'all\',this)">All</button>';
