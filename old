// BUILD NOTE POOL
// ════════════════════════════════════════════════════════════════
function buildPool(){
  const inst=INSTRUMENTS[selInst];
  const pitchSet=new Set();
  selScales.forEach(s=>ALL_SCALES[s].notes.forEach(n=>pitchSet.add(normalize(n))));
  const p=[];
  pitchSet.forEach(concert=>{
    const written=transposePitch(concert,inst.transpose);
    const yData=findY(written,inst.clef,selInst);
    if(yData) p.push({concert,written,clef:inst.clef,...yData});
  });
  return p;
}

function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}}

// ════════════════════════════════════════════════════════════════
// GAME
// ════════════════════════════════════════════════════════════════
function startGame(){
  pool=buildPool();
  if(!pool.length){alert('No notes found for this combination. Try different scales.');return;}
  shuffle(pool);
  hist=[];histIdx=-1;sc=0;sw=0;answered=false;
  document.getElementById('gsc').textContent=0;
  document.getElementById('gsw').textContent=0;
  const inst=INSTRUMENTS[selInst];
  document.getElementById('gbadge').textContent=inst.name+' · '+inst.key;
  buildAnswerUI();
  showScreen('game');
  nextNote();
}

function buildAnswerUI(){
  const nb=document.getElementById('nbtns');nb.innerHTML='';
  ['C','D','E','F','G','A','B'].forEach(n=>{
    const b=document.createElement('button');
    b.className='nbtn';b.textContent=n;b.dataset.n=n;
    b.onclick=()=>pickLetter(n);nb.appendChild(b);
  });
  const ab=document.getElementById('acbtns');ab.innerHTML='';
  [['♮ Natural',''],['♭ Flat','b'],['♯ Sharp','#']].forEach(([l,v])=>{
    const b=document.createElement('button');
    b.className='acbtn'+(v===''?' sel':'');b.textContent=l;b.dataset.v=v;
    b.onclick=()=>pickAcc(v);ab.appendChild(b);
  });
  selAcc='';selLetter=null;
}

function pickLetter(n){
  selLetter=n;
  document.querySelectorAll('.nbtn').forEach(b=>b.classList.toggle('sel',b.dataset.n===n));
  updateDisp();
}
function pickAcc(v){
  selAcc=v;
  document.querySelectorAll('.acbtn').forEach(b=>b.classList.toggle('sel',b.dataset.v===v));
  updateDisp();
}
function updateDisp(){
  const d=document.getElementById('ansdisp');
  if(!selLetter){d.textContent='—';return;}
  d.textContent=selLetter+(selAcc==='b'?'♭':selAcc==='#'?'♯':'');
}

function resetInput(){
  selLetter=null;selAcc='';
  document.querySelectorAll('.nbtn').forEach(b=>b.classList.remove('sel','fc','fw'));
  document.querySelectorAll('.acbtn').forEach(b=>b.classList.toggle('sel',b.dataset.v===''));
  document.getElementById('ansdisp').textContent='—';
}

function nextNote(){
  histIdx++;
  if(histIdx>=hist.length){
    cur=pool[Math.floor(Math.random()*pool.length)];
    hist.push(cur);
  } else { cur=hist[histIdx]; }
  answered=false;
  resetInput();
  document.getElementById('ipanel').classList.remove('show');
  document.getElementById('cmsg').style.display='none';
  document.getElementById('sqlbl').textContent='IDENTIFY THIS NOTE';
  drawStaff(false,null);
  updateProg();
}

function retry(){
  answered=false;resetInput();
  document.getElementById('ipanel').classList.remove('show');
  document.getElementById('cmsg').style.display='none';
  document.getElementById('sqlbl').textContent='IDENTIFY THIS NOTE';
  drawStaff(false,null);
}

function checkAns(){
  if(answered){nextNote();return;}
  if(!selLetter) return;
  const user=normalize(selLetter+(selAcc==='b'?'b':selAcc==='#'?'#':''));
  const correct=normalize(cur.written);
  // enharmonic equivalence
  const match = user===correct ||
    SEMI.indexOf(user)===SEMI.indexOf(correct);
  answered=true;
  if(match){
    sc++;
    doFlash('c');
    document.getElementById('cmsg').style.display='block';
    document.getElementById('sqlbl').textContent=correct+' ✓';
    document.querySelectorAll('.nbtn').forEach(b=>{if(b.dataset.n===selLetter)b.classList.add('fc');});
    drawStaff(true,true);
  } else {
    sw++;
    doFlash('w');
    document.getElementById('sqlbl').textContent='Answer: '+correct;
    document.querySelectorAll('.nbtn').forEach(b=>{if(b.dataset.n===selLetter)b.classList.add('fw');});
    drawStaff(true,false);
    showInfo();
  }
  document.getElementById('gsc').textContent=sc;
  document.getElementById('gsw').textContent=sw;
}

function doFlash(t){
  const f=document.getElementById('flash');f.className=t;
  setTimeout(()=>f.className='',400);
}
function updateProg(){
  document.getElementById('prog').style.width=Math.min(sc/Math.max(pool.length,1)*100,100)+'%';
}

// ════════════════════════════════════════════════════════════════
// STAFF DRAWING — improved clarity
// ════════════════════════════════════════════════════════════════
function svgEl(svg,ns,tag,attrs){
  const el=document.createElementNS(ns,tag);
  Object.entries(attrs).forEach(([k,v])=>el.setAttribute(k,v));
  return el;
}

function drawStaff(reveal,correct){
  const svg=document.getElementById('staff-svg');
  svg.innerHTML='';
  const ns='http://www.w3.org/2000/svg';
  const W=760;

  // bg
  svg.appendChild(svgEl(svg,ns,'rect',{x:0,y:0,width:W,height:200,fill:'#090b10'}));

  const lineX1=95, lineX2=W-50;

  // Line labels (mnemonic)
  const lineLabels = cur.clef==='bass'
    ? ['G2','B2','D3','F3','A3']
    : cur.clef==='alto'
    ? ['F3','A3','C4','E4','G4']
    : ['E4','G4','B4','D5','F5'];
  const spaceLabels = cur.clef==='bass'
    ? ['A2','C3','E3','G3']
    : cur.clef==='alto'
    ? ['G3','B3','D4','F4']
    : ['F4','A4','C5','E5'];

  // Staff lines
  LINE_Y.forEach((y,i)=>{
    svg.appendChild(svgEl(svg,ns,'line',{x1:lineX1,y1:y,x2:lineX2,y2:y,stroke:'#2d3a50','stroke-width':1.5}));
    // right-side label
    const t=document.createElementNS(ns,'text');
    t.setAttribute('x',lineX2+6);t.setAttribute('y',y+4);
    t.setAttribute('font-size','9');t.setAttribute('fill','#2d3a50');
    t.setAttribute('font-family','Fira Code, monospace');
    t.textContent=lineLabels[i];
    svg.appendChild(t);
  });
  // space labels
  const sY=[107,91,75,59];
  spaceLabels.forEach((lbl,i)=>{
    const t=document.createElementNS(ns,'text');
    t.setAttribute('x',lineX2+6);t.setAttribute('y',sY[i]+4);
    t.setAttribute('font-size','9');t.setAttribute('fill','#1e2a3a');
    t.setAttribute('font-family','Fira Code, monospace');
    t.textContent=lbl;
    svg.appendChild(t);
  });

  // Clef symbol
  if(cur.clef==='treble'){
    const c=document.createElementNS(ns,'text');
    c.setAttribute('x','16');c.setAttribute('y','116');
    c.setAttribute('font-size','95');c.setAttribute('fill','#3a4a60');
    c.setAttribute('font-family','serif');c.textContent='𝄞';
    svg.appendChild(c);
  } else if(cur.clef==='bass'){
    const c=document.createElementNS(ns,'text');
    c.setAttribute('x','18');c.setAttribute('y','95');
    c.setAttribute('font-size','78');c.setAttribute('fill','#3a4a60');
    c.setAttribute('font-family','serif');c.textContent='𝄢';
    svg.appendChild(c);
  } else { // alto
    const c=document.createElementNS(ns,'text');
    c.setAttribute('x','16');c.setAttribute('y','102');
    c.setAttribute('font-size','78');c.setAttribute('fill','#3a4a60');
    c.setAttribute('font-family','serif');c.textContent='𝄡';
    svg.appendChild(c);
  }

  const noteX=370;
  const noteY=cur.y;

  // Highlight band showing where the note is
  const onLine=LINE_Y.some(y=>Math.abs(y-noteY)<5);
  if(onLine){
    const nearLine=LINE_Y.find(y=>Math.abs(y-noteY)<5);
    svg.appendChild(svgEl(svg,ns,'rect',{x:noteX-45,y:nearLine-10,width:90,height:20,fill:'rgba(110,231,247,0.04)'}));
  } else {
    svg.appendChild(svgEl(svg,ns,'rect',{x:noteX-45,y:noteY-9,width:90,height:18,fill:'rgba(110,231,247,0.04)'}));
  }

  // Ledger lines (above/below staff)
  (cur.ll||[]).forEach(ly=>{
    svg.appendChild(svgEl(svg,ns,'line',{x1:noteX-20,y1:ly,x2:noteX+20,y2:ly,stroke:'#3d4f68','stroke-width':1.5}));
  });

  // Subtle vertical guide from note to label area
  svg.appendChild(svgEl(svg,ns,'line',{x1:noteX,y1:Math.max(noteY,50),x2:noteX,y2:160,stroke:'rgba(110,231,247,0.06)','stroke-width':1,'stroke-dasharray':'3,4'}));

  // Position label at bottom
  if(cur.label){
    const t=document.createElementNS(ns,'text');
    t.setAttribute('x',noteX);t.setAttribute('y',180);
    t.setAttribute('font-size','9');t.setAttribute('fill','rgba(110,231,247,0.35)');
    t.setAttribute('text-anchor','middle');
    t.setAttribute('font-family','Fira Code, monospace');
    t.textContent=cur.label;
    svg.appendChild(t);
  }

  // Mini position indicator (right margin)
  drawMiniStaff(svg,ns,noteY);

  if(!reveal){
    // Question oval with ?
    svg.appendChild(svgEl(svg,ns,'ellipse',{cx:noteX,cy:noteY,rx:13,ry:9,fill:'none',stroke:'#6ee7f7','stroke-width':2,transform:`rotate(-15,${noteX},${noteY})`}));
    const q=document.createElementNS(ns,'text');
    q.setAttribute('x',noteX);q.setAttribute('y',noteY+5);
    q.setAttribute('font-size','13');q.setAttribute('fill','#6ee7f7');
    q.setAttribute('text-anchor','middle');q.setAttribute('font-weight','bold');
    q.setAttribute('font-family','Fira Code, monospace');
    q.textContent='?';
    svg.appendChild(q);
  } else {
    const col=correct?'#4fffb0':'#ff6b6b';
    // Filled note head
    svg.appendChild(svgEl(svg,ns,'ellipse',{cx:noteX,cy:noteY,rx:12,ry:8,fill:col,transform:`rotate(-15,${noteX},${noteY})`}));
    // Stem
    const up=noteY>82;
    svg.appendChild(svgEl(svg,ns,'line',{
      x1:up?noteX+10:noteX-10,y1:noteY,
      x2:up?noteX+10:noteX-10,y2:noteY+(up?-44:44),
      stroke:col,'stroke-width':2
    }));
    // Accidental symbol on note
    const w=cur.written;
    if(w.includes('b')){
      const acc=document.createElementNS(ns,'text');
      acc.setAttribute('x',noteX-22);acc.setAttribute('y',noteY+6);
      acc.setAttribute('font-size','20');acc.setAttribute('fill',col);
      acc.setAttribute('font-family','serif');acc.textContent='♭';
      svg.appendChild(acc);
    } else if(w.endsWith('#')||['Db','Eb','Gb','Ab'].includes(w)){
      // shown via note name label
    }
    // Note name label above
    const nl=document.createElementNS(ns,'text');
    nl.setAttribute('x',noteX);nl.setAttribute('y',noteY-(up?48:12)-8);
    nl.setAttribute('font-size','14');nl.setAttribute('fill',col);
    nl.setAttribute('text-anchor','middle');
    nl.setAttribute('font-family','Unbounded, sans-serif');nl.setAttribute('font-weight','700');
    nl.textContent=cur.written;
    svg.appendChild(nl);
  }
}

function drawMiniStaff(svg,ns,noteY){
  const mx=710, mw=16;
  const scY=y=>30+(y-20)*(150/155);
  LINE_Y.forEach(y=>{
    svg.appendChild(svgEl(svg,ns,'line',{x1:mx,y1:scY(y),x2:mx+mw,y2:scY(y),stroke:'#1e2a3a','stroke-width':1}));
  });
  const ny=scY(noteY);
  svg.appendChild(svgEl(svg,ns,'circle',{cx:mx+mw/2,cy:ny,r:4,fill:'#6ee7f7'}));
  svg.appendChild(svgEl(svg,ns,'line',{x1:mx-5,y1:ny,x2:mx-1,y2:ny,stroke:'#6ee7f7','stroke-width':1}));
}

// ════════════════════════════════════════════════════════════════
// INFO PANEL
// ════════════════════════════════════════════════════════════════
function showInfo(){
  const inst=INSTRUMENTS[selInst];
  const ft=inst.fingeringType||inst.ft;
  const pitch=cur.concert.replace(/[0-9]/g,'');
  const panel=document.getElementById('ipanel');panel.classList.add('show');

  document.getElementById('iptitle').textContent=
    `${cur.written} written · ${cur.concert} concert · ${cur.noteId}`;

  let fingHTML='';
  if(ft==='trombone'){
    const d=FING.trombone[pitch];
    if(d){
      const dots=[];
      for(let i=1;i<=7;i++) dots.push(`<div class="fdot${d.pos.includes(i)?' on':''}">${i}</div>`);
      (d.alt||[]).forEach(a=>dots.push(`<div class="fdot on tag">${a}</div>`));
      fingHTML=`<div class="frow">${dots.join('')}</div><p style="font-size:10px;color:var(--muted);margin-top:5px">${d.tip}</p>`;
    }
  } else if(ft==='valve3'){
    const d=FING.valve3[pitch];
    if(d){
      const dots=d.v.map((v,i)=>`<div class="fdot${v?' on':''}">${i+1}</div>`).join('');
      fingHTML=`<div class="frow">${dots}</div><p style="font-size:10px;color:var(--muted);margin-top:5px">${d.desc}</p>`;
    }
  } else {
    const map={'horn':FING.horn,'sax':FING.sax,'clarinet':FING.clarinet,'flute':FING.flute,
               'oboe':FING.oboe,'bassoon':FING.bassoon,'bowed':FING.bowed,'keys':FING.keys};
    const fd=(map[ft]||{})[pitch];
    if(fd) fingHTML=`<p>${fd}</p>`;
  }

  const scMembership=[...selScales].filter(s=>ALL_SCALES[s].notes.map(n=>normalize(n)).includes(normalize(cur.concert))).join(', ');
  const onLine=LINE_Y.some(y=>Math.abs(y-cur.y)<5);

  document.getElementById('ipcols').innerHTML=`
    <div class="ipc"><label>Fingering / Position</label>${fingHTML||'<p>See your method book.</p>'}</div>
    <div class="ipc">
      <label>Written Note</label>
      <p style="font-size:28px;font-family:'Unbounded',sans-serif;font-weight:900;color:var(--gold)">${cur.written}</p>
      <p style="font-size:10px;color:var(--muted)">Concert: ${cur.concert} · ID: ${cur.noteId}</p>
    </div>
    <div class="ipc"><label>In These Selected Scales</label><p>${scMembership||'—'}</p></div>
    <div class="ipc"><label>Instrument Info</label><p style="font-size:10px">${inst.desc}</p></div>`;

  document.getElementById('iphint').innerHTML=
    `<strong>Staff:</strong> ${cur.label||cur.noteId} · ${onLine?'ON a staff line':'IN a space between lines'}<br>`+
    `<strong>Clef:</strong> ${inst.clef==='treble'?'Treble: lines = E G B D F · spaces = F A C E':inst.clef==='alto'?'Alto: middle line = C4 (middle C)':'Bass: lines = G B D F A · spaces = A C E G'}<br>`+
    `<strong>Note:</strong> ${ALL_SCALES[[...selScales][0]]?.tip||'Count carefully from the bottom line of the staff.'}`;
}

// ════════════════════════════════════════════════════════════════
// GUIDE SCREEN
// ════════════════════════════════════════════════════════════════
function showGuide(){
  buildGuideFilters();
  buildGuideCards();
  showScreen('guide');
}

function buildGuideFilters(){
  const row=document.getElementById('guide-filter-row');row.innerHTML='';
  const b0=document.createElement('button');
  b0.className='ftag on';b0.dataset.cat='all';b0.textContent='All';
  b0.onclick=()=>setGuideFilter('all',b0);row.appendChild(b0);
  Object.keys(SCALE_CATS).forEach(cat=>{
    const b=document.createElement('button');
    b.className='ftag';b.dataset.cat=cat;b.textContent=cat;
    b.onclick=()=>setGuideFilter(cat,b);row.appendChild(b);
  });
}

let guideCat='all';
function setGuideFilter(cat,btn){
  guideCat=cat;
  document.querySelectorAll('#guide-filter-row .ftag').forEach(b=>b.classList.toggle('on',b.dataset.cat===cat));
  filterGuide();
}

function buildGuideCards(){
  const g=document.getElementById('guide-grid');g.innerHTML='';
  Object.entries(ALL_SCALES).forEach(([name,d])=>{
    const col=SCALE_CATS[d.c]||'#888';
    const card=document.createElement('div');
    card.className='gcard';
    card.style.borderTopColor=col;
    card.dataset.name=name.toLowerCase();
    card.dataset.cat=d.c;
    card.dataset.notes=(d.notes||[]).join(' ').toLowerCase();
    const pills=(d.notes||[]).map(n=>`<span class="gpill">${n}</span>`).join('');
    const pronHtml=d.pron?`<div style="font-size:9px;color:var(--purple);margin-bottom:6px;letter-spacing:0.1em">🔊 ${d.pron}</div>`:'';
    card.innerHTML=`
      <div class="gcat-tag">${d.c}</div>
      <h3 style="color:${col}">${name}</h3>
      ${pronHtml}
      <div class="gpills">${pills}</div>
      <p>${d.desc}</p>
      <div class="gtip"><strong>Tip:</strong> ${d.tip||'Practice slowly.'}</div>`;
    g.appendChild(card);
  });
}

function filterGuide(){
  const q=document.getElementById('guide-search').value.toLowerCase();
  document.querySelectorAll('.gcard').forEach(c=>{
    const catOk=guideCat==='all'||c.dataset.cat===guideCat;
    const qOk=!q||c.dataset.name.includes(q)||c.dataset.cat.toLowerCase().includes(q)||c.dataset.notes.includes(q);
    c.classList.toggle('hidden',!(catOk&&qOk));
  });
}

